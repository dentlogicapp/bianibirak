# BiAniBirak - ornek ortam degiskenleri. Gercek .env repoya GIRMEZ;
# sunucuda /opt/bianibirak/.env olarak durur.

# Frontend
NODE_ENV=production

# Postgres (bianibirak-postgres + backend baglantisi bunlardan turer)
POSTGRES_DB=bianibirak
POSTGRES_USER=bianibirakuser
POSTGRES_PASSWORD=degistir_guclu_bir_sifre

# JWT imzalama anahtari - EN AZ 32 karakter, uzun ve rastgele olmali.
# Uret: openssl rand -base64 48
JWT_SECRET=degistir_uzun_rastgele_deger_en_az_32_karakter
